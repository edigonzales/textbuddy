# LLM-Provider (Pflicht für Produktionsbetrieb)
TEXTBUDDY_LLM_MODE=provider
TEXTBUDDY_LLM_BASE_URL=https://api.openai.com/v1
TEXTBUDDY_LLM_API_KEY=<set-your-key>
TEXTBUDDY_LLM_MODEL=gpt-5.4-mini

# Sidecar-freier Standardbetrieb
TEXTBUDDY_LANGUAGETOOL_MODE=embedded
TEXTBUDDY_DOCUMENT_MODE=kreuzberg

# Lokale Laufzeitressourcen
TEXTBUDDY_RUNTIME_HOME=/opt/textbuddy/runtime
TEXTBUDDY_RUNTIME_INITIALIZE_LOCAL_RESOURCES=true

# Optional
TEXTBUDDY_AUTH_ENABLED=false
TEXTBUDDY_DOCUMENT_MAX_UPLOAD_SIZE=20MB
TEXTBUDDY_LLM_TIMEOUT=30s
TEXTBUDDY_LANGUAGETOOL_TIMEOUT=10s
TEXTBUDDY_DOCUMENT_TIMEOUT=45s
